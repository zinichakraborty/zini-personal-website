---
import Hero from '../layouts/Hero.astro';
import { SITE_TITLE } from '../consts';

const experience = [
	{
		title: 'Software Engineer Intern',
		org: 'Bloomberg',
		location: 'New York, NY',
		dates: 'June 2025 – August 2025',
		bullets: [
			'Built first-of-its-kind, full-stack C++ app for transparent portfolio aggregations via the Bloomberg Terminal',
			'Reduced runtime from tens of minutes to seconds with a lightweight, parallelized backend service and UI',
			'Coordinated with cross-team developers to integrate Splunk API trace calls, diagnosing client-reported issues',
		],
	},
	{
		title: 'Machine Learning Teaching Assistant',
		org: 'Georgia Institute of Technology',
		location: 'Atlanta, GA',
		dates: 'August 2024 – May 2026',
		bullets: [
			'Building retrieval-augmented fine-tuned EdStem LLM agent with dynamic databases for Socratic Q&A',
			'Automate assignment grading through code image detection, instruct students in project design and office hours',
		],
	},
	{
		title: 'Solutions Engineering Intern',
		org: 'Deloitte Consulting',
		location: 'Nashville, TN',
		dates: 'June 2024 – July 2024',
		bullets: [
			'Handle end-to-end production in State of Tennessee Eligibility Benefits Management System Portals in Java Spring',
			'Discuss with clients on defects and enhancements, actualize SummerEBT Appeals, 600K+ eligible yearly',
			'Develop DevOps Python automation to restart failing JVMs and Streamlit LLM tool to recommend course paths',
		],
	},
];

const education = [
	{
		degree: 'M.S. in Computer Science',
		org: 'Georgia Institute of Technology',
		location: 'Atlanta, GA',
		dates: 'August 2025 – May 2026',
		concentration: 'Machine Learning',
		option: 'Research Project Option',
	},
	{
		degree: 'B.S. in Computer Science',
		org: 'Georgia Institute of Technology',
		location: 'Atlanta, GA',
		dates: 'August 2022 – May 2025',
		concentration: 'AI and Networks',
		option: 'Research Option',
	},
];
---

<Hero title={`Background | ${SITE_TITLE}`} description="Background of Chandreyi (Zini) Chakraborty.">
	<h2>Experience</h2>
	<div class="timeline">
		{
			experience.map((job) => (
				<section class="job">
					<div class="job-head">
						<span class="job-title">{job.title}</span>
						<span class="job-dates">{job.dates}</span>
					</div>
					<div class="job-meta">
						<span class="job-org">{job.org}</span> · {job.location}
					</div>
					<ul>
						{job.bullets.map((bullet) => (
							<li>{bullet}</li>
						))}
					</ul>
				</section>
			))
		}
	</div>

	<h2>Education</h2>
	<div class="timeline">
		{
			education.map((ed) => (
				<section class="job">
					<div class="job-head">
						<span class="job-title">{ed.degree}</span>
						<span class="job-dates">{ed.dates}</span>
					</div>
					<div class="job-meta">
						<span class="job-org">{ed.org}</span> · {ed.location}
					</div>
					<div class="ed-detail">
						{ed.concentration} · {ed.option}
					</div>
				</section>
			))
		}
	</div>
</Hero>

<style>
	h2 {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		font-size: 1.45rem;
		margin: 2.25rem 0 1.25rem;
	}
	h2:first-of-type {
		margin-top: 0.25rem;
	}
	h2::before {
		content: '';
		width: 0.45rem;
		height: 1.3rem;
		border-radius: 999px;
		background: hsl(320, 100%, 70%);
	}

	.job {
		padding: 1rem 0;
		border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.job:last-child {
		border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.job-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.job-title {
		font-weight: 700;
		font-size: 1.05rem;
	}
	.job-dates {
		font-size: 0.82rem;
		white-space: nowrap;
		opacity: 0.6;
		font-variant-numeric: tabular-nums;
	}
	.job-meta {
		font-size: 0.92rem;
		margin-top: 0.25rem;
	}
	.job-org {
		color: hsl(220, 100%, 72%);
		font-weight: 600;
	}
	.job ul {
		margin-top: 0.65rem;
		padding-left: 1.1rem;
		list-style: none;
	}
	.job li {
		position: relative;
		margin-bottom: 0.35rem;
		line-height: 1.55;
		font-size: 0.95rem;
	}
	.job li::before {
		content: '▹';
		position: absolute;
		left: -1.1rem;
		color: hsl(320, 100%, 70%);
	}

	.ed-detail {
		margin-top: 0.4rem;
		font-size: 0.9rem;
		font-style: italic;
		opacity: 0.75;
	}
</style>
