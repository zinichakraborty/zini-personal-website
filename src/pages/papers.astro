---
import Hero from '../layouts/Hero.astro';
import { SITE_TITLE } from '../consts';

// Pulled from Google Scholar. Update as new papers come out.
const papers = [
	{
		title: 'On the Quantization Robustness of Diffusion Language Models in Coding Benchmarks',
		authors: 'A Gupta, G Deshpande, C Chakraborty',
		venue: 'arXiv preprint',
		year: 2026,
		coFirst: true,
		link: 'https://arxiv.org/abs/2604.20079',
	},
	{
		title: 'Do Language Models Agree with Human Perceptions of Suspense in Stories?',
		authors: 'G Matlin, D Zhang, RB Loza, DM Popescu, J Isbell, C Chakraborty, et al.',
		venue: 'Conference on Language Modeling (COLM)',
		year: 2025,
		coFirst: false,
		link: 'https://arxiv.org/abs/2508.15794',
	},
	{
		title: 'Diffusion Model for Generating Inorganic Materials with Targeted Density of States',
		authors: 'C Chakraborty',
		venue: 'Georgia Institute of Technology',
		year: 2025,
		coFirst: false,
		link: 'https://repository.gatech.edu/entities/publication/ed62e6cb-43c1-445f-b9a5-5bd4b261ed89',
	},
];

// Mark co-first authors with * and bold the site owner's name.
const formatAuthors = (paper) => {
	const names = paper.coFirst
		? paper.authors
				.split(', ')
				.map((name) => (name === 'et al.' ? name : `${name}*`))
				.join(', ')
		: paper.authors;
	return names.replace(
		paper.coFirst ? 'C Chakraborty*' : 'C Chakraborty',
		`<strong>C Chakraborty${paper.coFirst ? '*' : ''}</strong>`,
	);
};
---

<Hero title={`Papers | ${SITE_TITLE}`} description="Publications by Chandreyi (Zini) Chakraborty.">
	<h1>Papers</h1>
	<p class="intro">Research in interpretability, ML systems, and NLP.</p>
	<ol class="papers">
		{
			papers.map((paper) => (
				<li class="paper">
					<span class="year">{paper.year}</span>
					<div class="content">
						<a class="title" href={paper.link} target="_blank" rel="noopener">
							{paper.title}
						</a>
						<span class="authors" set:html={formatAuthors(paper)} />
						<span class="venue">
							<em>{paper.venue}</em>
							{paper.coFirst && <span class="cofirst"> (* Equal contribution)</span>}
						</span>
					</div>
				</li>
			))
		}
	</ol>
</Hero>

<style>
	.intro {
		margin: 0.25rem 0 0 0;
		opacity: 0.75;
	}
	.papers {
		list-style: none;
		padding: 0;
		margin: 1.75rem 0 0 0;
	}
	.paper {
		display: grid;
		grid-template-columns: 3.5rem 1fr;
		gap: 1.25rem;
		padding: 1rem 0;
		border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.paper:last-child {
		border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.year {
		font-size: 0.85rem;
		font-variant-numeric: tabular-nums;
		opacity: 0.6;
		padding-top: 0.2rem;
		white-space: nowrap;
	}
	.content {
		min-width: 0;
	}
	.title {
		display: block;
		font-weight: 700;
		font-size: 1.05rem;
		line-height: 1.4;
		color: hsl(220, 100%, 72%);
		text-decoration: none;
	}
	.authors {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.92rem;
		line-height: 1.5;
	}
	.venue {
		display: block;
		margin-top: 0.2rem;
		font-size: 0.88rem;
		opacity: 0.7;
	}
	.cofirst {
		font-size: 0.8rem;
	}

	@media (max-width: 32rem) {
		.paper {
			grid-template-columns: 1fr;
			gap: 0.3rem;
		}
		.year {
			padding-top: 0;
		}
	}
</style>
