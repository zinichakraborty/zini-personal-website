---
import Hero from '../layouts/Hero.astro';
import { SITE_TITLE } from '../consts';

// Pulled from Google Scholar. Update as new papers come out.
const papers = [
	{
		title: 'On the Quantization Robustness of Diffusion Language Models in Coding Benchmarks',
		authors: 'A Gupta, G Deshpande, C Chakraborty',
		venue: 'arXiv preprint',
		year: 2026,
		coFirst: true,
		link: 'https://arxiv.org/abs/2604.20079',
	},
	{
		title: 'Do Language Models Agree with Human Perceptions of Suspense in Stories?',
		authors: 'G Matlin, D Zhang, RB Loza, DM Popescu, J Isbell, C Chakraborty, et al.',
		venue: 'Conference on Language Modeling (COLM)',
		year: 2025,
		coFirst: false,
		link: 'https://arxiv.org/abs/2508.15794',
	},
	{
		title: 'Diffusion Model for Generating Inorganic Materials with Targeted Density of States',
		authors: 'C Chakraborty',
		venue: 'Georgia Institute of Technology',
		year: 2025,
		coFirst: false,
		link: 'https://repository.gatech.edu/entities/publication/ed62e6cb-43c1-445f-b9a5-5bd4b261ed89',
	},
];
---

<Hero title={`Papers | ${SITE_TITLE}`} description="Publications by Chandreyi (Zini) Chakraborty." fit>
	<h1>Papers</h1>
			<p>Research in interpretability, ML systems, and NLP.</p>
			<ul class="papers">
				{
					papers.map((paper) => (
						<li class="paper">
							<a class="title" href={paper.link} target="_blank" rel="noopener">
								{paper.title}
							</a>
							<span
								class="authors"
								set:html={(paper.coFirst
									? paper.authors
											.split(', ')
											.map((name) => `${name}*`)
											.join(', ')
									: paper.authors
								).replace(
									paper.coFirst ? 'C Chakraborty*' : 'C Chakraborty',
									`<strong>C Chakraborty${paper.coFirst ? '*' : ''}</strong>`,
								)}
							/>
							<div class="paper-meta">
								<span class="tag venue">{paper.venue}</span>
								<span class="tag year">{paper.year}</span>
								{paper.coFirst && <span class="tag cofirst">Co-first author *</span>}
							</div>
						</li>
					))
				}
			</ul>
</Hero>

<style>
	.papers {
		list-style: none;
		padding: 0;
		margin: 2rem 0 0 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.paper {
		padding: 1.2rem 1.4rem;
		border-radius: 0.9rem;
		background: color-mix(in srgb, currentColor 5%, transparent);
		border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
		border-left: 3px solid hsl(220, 100%, 70%);
		transition:
			transform 0.18s ease,
			background 0.18s ease,
			border-left-color 0.18s ease;
	}
	.paper:hover {
		transform: translateX(3px);
		background: color-mix(in srgb, currentColor 8%, transparent);
		border-left-color: hsl(320, 100%, 70%);
	}
	.title {
		display: block;
		font-weight: 700;
		font-size: 1.1rem;
		color: inherit;
		text-decoration: none;
	}
	.title:hover {
		text-decoration: underline;
	}
	.authors {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.95rem;
	}
	.paper-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.85rem;
	}
	.tag {
		font-size: 0.8rem;
		padding: 0.25rem 0.7rem;
		border-radius: 999px;
		background: color-mix(in srgb, currentColor 7%, transparent);
		border: 1px solid color-mix(in srgb, currentColor 14%, transparent);
	}
	.tag.year {
		font-weight: 600;
	}
	.tag.cofirst {
		color: hsl(320, 100%, 70%);
		border-color: color-mix(in srgb, hsl(320, 100%, 70%) 45%, transparent);
	}
</style>
