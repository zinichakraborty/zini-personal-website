---
import Hero from '../layouts/Hero.astro';
import { SITE_TITLE } from '../consts';

// Recent updates. Add new entries to the top.
const news = [
	{
		date: 'Jun 2026',
		org: 'Allen Institute for AI (AI2)',
		orgLink: 'https://allenai.org',
		body: 'Invited to interview with Kyle Lo to advance research on social reasoning data attribution in OLMo 3, AI2’s fully open frontier language model.',
	},
	{
		date: 'Jan 2026',
		org: 'EleutherAI',
		orgLink: 'https://www.eleuther.ai',
		body: 'Partnered with the team behind Bergson to extend their gradient-based attribution methods to social reasoning, tracing model behavior back to its training data.',
	},
	{
		date: 'Jan 2024',
		org: 'Bits of Good',
		orgLink: 'https://bitsofgood.org',
		body: 'Co-developed a full-stack web platform for Heart of Passion, an Atlanta non-profit serving youth cancer patients, streamlining donations and event coordination for the organization.',
		link: 'https://github.com/GTBitsOfGood/heart-of-passion',
	},
	{
		date: 'Jul 2021',
		org: 'UCSB Research Mentorship Program',
		orgLink: 'https://www.summer.ucsb.edu/programs/research-mentorship-program/overview',
		body: 'Presented original mathematics research to an audience of 100+, collaborating with PhD candidate Andres Barei on a method to determine whether a given algebra is standardly stratified.',
	},
	{
		date: 'Jul 2020',
		org: 'UCSB Summer Research Academies',
		orgLink: 'https://www.summer.ucsb.edu/programs/summer-research-academies/overview',
		body: 'Presented at a research seminar to 100+ attendees on a Siamese neural network that jointly predicts the driveability and terrain of car-view landscapes for autonomous navigation.',
		link: 'https://github.com/zinichakraborty/Using-Deep-Learning-to-Analyze-the-Driveability-of-Autonomous-Vehicles-on-Unmarked-Terrain',
	},
];
---

<Hero title={`News | ${SITE_TITLE}`} description="Recent updates from Chandreyi (Zini) Chakraborty.">
	<h1>News</h1>
	<ul class="news">
		{
			news.map((item) => (
				<li class="item">
					<span class="date">{item.date}</span>
					<div class="content">
						<div class="org-row">
							{item.orgLink ? (
								<a class="org" href={item.orgLink} target="_blank" rel="noopener">
									{item.org}
								</a>
							) : (
								<span class="org">{item.org}</span>
							)}
						</div>
						<p class="body">
							{item.body}
							{item.link && (
								<>
									{' '}
									<a class="item-link" href={item.link} target="_blank" rel="noopener">
										[link]
									</a>
								</>
							)}
						</p>
					</div>
				</li>
			))
		}
	</ul>
</Hero>

<style>
	.news {
		list-style: none;
		padding: 0;
		margin: 1.75rem 0 0 0;
	}
	.item {
		display: grid;
		grid-template-columns: 6.5rem 1fr;
		gap: 1.25rem;
		padding: 0.9rem 0;
		border-top: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.item:last-child {
		border-bottom: 1px solid color-mix(in srgb, currentColor 12%, transparent);
	}
	.date {
		font-size: 0.85rem;
		font-variant-numeric: tabular-nums;
		padding-top: 0.1rem;
		opacity: 0.65;
		white-space: nowrap;
	}
	.content {
		min-width: 0;
	}
	.org-row {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
	}
	.org {
		font-weight: 700;
		font-size: 1.05rem;
		color: hsl(220, 100%, 72%);
		text-decoration: none;
	}
	a.org:hover {
		text-decoration: underline;
	}
	.body {
		margin: 0.3rem 0 0 0;
		line-height: 1.55;
	}
	.item-link {
		font-size: 0.8rem;
		color: hsl(220, 100%, 72%);
		text-decoration: none;
		font-weight: 600;
		white-space: nowrap;
	}
	.item-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 32rem) {
		.item {
			grid-template-columns: 1fr;
			gap: 0.3rem;
		}
		.date {
			padding-top: 0;
		}
	}
</style>
