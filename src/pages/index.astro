---
import Hero from '../layouts/Hero.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// === Papers === (pulled from Google Scholar; update as new papers come out)
const papers = [
	{
		title: 'Where Does Social Reasoning Come From? Capability Provenance in Language Models',
		authors: 'G Matlin, C Chakraborty, S Eom, M Okamoto, R Castilla, et al.',
		venue: 'arXiv preprint',
		year: 2026,
		coFirst: false,
		link: 'https://arxiv.org/abs/2606.19625',
	},
	{
		title: 'On the Quantization Robustness of Diffusion Language Models in Coding Benchmarks',
		authors: 'A Gupta, G Deshpande, C Chakraborty',
		venue: 'arXiv preprint',
		year: 2026,
		coFirst: true,
		link: 'https://arxiv.org/abs/2604.20079',
	},
	{
		title: 'Do Language Models Agree with Human Perceptions of Suspense in Stories?',
		authors: 'G Matlin, D Zhang, RB Loza, DM Popescu, J Isbell, C Chakraborty, et al.',
		venue: 'Conference on Language Modeling (COLM)',
		year: 2025,
		coFirst: false,
		link: 'https://arxiv.org/abs/2508.15794',
	},
	{
		title: 'Diffusion Model for Generating Inorganic Materials with Targeted Density of States',
		authors: 'C Chakraborty',
		venue: 'Georgia Institute of Technology',
		year: 2025,
		coFirst: false,
		link: 'https://repository.gatech.edu/entities/publication/ed62e6cb-43c1-445f-b9a5-5bd4b261ed89',
	},
];

// Mark co-first authors with * and bold the site owner's name.
const formatAuthors = (paper) => {
	const names = paper.coFirst
		? paper.authors
				.split(', ')
				.map((name) => (name === 'et al.' ? name : `${name}*`))
				.join(', ')
		: paper.authors;
	return names.replace(
		paper.coFirst ? 'C Chakraborty*' : 'C Chakraborty',
		`<strong>C Chakraborty${paper.coFirst ? '*' : ''}</strong>`,
	);
};

// === Contributions ===
const contributions = [
	{
		date: '2024',
		org: 'Bits of Good',
		orgLink: 'https://bitsofgood.org',
		body: 'Co-implemented an SDK, email/Amazon S3 file services, and user onboarding for faster app deployment.',
		link: 'https://github.com/GTBitsOfGood/juno',
	},
	{
		date: '2024',
		org: 'Heart of Passion',
		orgLink: 'https://www.heartofpassion.org/',
		body: 'Co-built a donation and event coordination platform for the non-profit, giving chapter organizers a single place to manage retreats for teens fighting cancer.',
		link: 'https://github.com/GTBitsOfGood/heart-of-passion',
	},
];
---

<Hero title={SITE_TITLE} description={SITE_DESCRIPTION} bare>
	<section id="home" class="card section section-home">
		<img
			class="hero-avatar"
			src="/profilepic.png"
			alt="Chandreyi (Zini) Chakraborty"
			width="860"
			height="780"
		/>
		<h1 class="hero-name">Hi, I'm Chandreyi (Zini) Chakraborty</h1>
		<p class="hero-fact">BS/MS CS @ Georgia Tech &nbsp;|&nbsp; AI Interpretability Research</p>
		<p class="hero-tagline">
			I earned my Masters and Bachelors in Computer Science from
			<a href="https://www.gatech.edu" target="_blank" rel="noopener noreferrer">Georgia Tech</a>,
			both with machine learning concentrations. My research focuses on uncovering LLM inner
			workings through mechanistic interpretability, and leveraging those insights to improve model
			capability and efficiency.
		</p>
		<p class="hero-tagline">
			I second-authored a
			<a href="https://arxiv.org/abs/2606.19625" target="_blank" rel="noopener noreferrer"
				>paper accepted to COLM 2026</a
			> that attributes social reasoning to training data at the corpus level, working with
			<a href="https://www.eleuther.ai" target="_blank" rel="noopener noreferrer">EleutherAI</a>. We
			launched a
			<a
				href="https://eilab.gatech.edu/capabilibara/"
				target="_blank"
				rel="noopener noreferrer">website</a
			> showcasing this work.
		</p>
		<p class="hero-tagline">
			I am a member of the
			<a href="https://eilab.gatech.edu" target="_blank" rel="noopener noreferrer"
				>Entertainment Intelligence and Human-Centered AI Lab</a
			> under
			<a href="https://eilab.gatech.edu/mark-riedl.html" target="_blank" rel="noopener noreferrer"
				>Dr. Mark Riedl</a
			>, where I published on
			<a href="https://arxiv.org/abs/2508.15794" target="_blank" rel="noopener noreferrer"
				>how LLMs understand suspense in stories (COLM 2025)</a
			>.
		</p>
		<p class="hero-tagline">
			I was a Machine Learning Teaching Assistant under
			<a href="https://mahdi-roozbahani.github.io/" target="_blank" rel="noopener noreferrer"
				>Dr. Mahdi Roozbahani</a
			>, where I developed a Socratic LLM agent that supports TAs in responding to student
			questions on EdStem using retrieval-augmented fine-tuning.
		</p>
		<p class="hero-tagline">
			On the efficiency side, I co-first-authored a
			<a href="https://arxiv.org/abs/2604.20079" target="_blank" rel="noopener noreferrer"
				>paper on the quantization robustness of diffusion LLMs</a
			> against autoregressive LLMs.
		</p>
		<p class="hero-tagline">
			Previously, I worked at
			<a
				href="https://professional.bloomberg.com/products/bloomberg-terminal/"
				target="_blank"
				rel="noopener noreferrer">Bloomberg</a
			>
			on the Terminal, building an efficient portfolio aggregation service, and before that at
			<a href="https://www.deloitte.com" target="_blank" rel="noopener noreferrer">Deloitte</a>,
			where I worked with the Tennessee state government to enhance their Eligibility Benefits
			Management Portal and integrate SummerEBT Appeals.
		</p>
	</section>

	<section id="publications" class="card section">
		<h2 class="section-title">Publications</h2>
		<ol class="papers">
			{
				papers.map((paper) => (
					<li class="paper">
						<span class="year">{paper.year}</span>
						<div class="content">
							<a class="title" href={paper.link} target="_blank" rel="noopener">
								{paper.title}
							</a>
							<span class="authors" set:html={formatAuthors(paper)} />
							<span class="venue">
								<em>{paper.venue}</em>
								{paper.coFirst && <span class="cofirst">*Equal contribution</span>}
							</span>
						</div>
					</li>
				))
			}
		</ol>
	</section>

	<section id="contributions" class="card section">
		<h2 class="section-title">Open-Source Contributions</h2>
		<ul class="news">
			{
				contributions.map((item) => (
					<li class="item">
						<span class="date">{item.date}</span>
						<div class="content">
							<div class="org-row">
								{item.orgLink ? (
									<a class="org" href={item.orgLink} target="_blank" rel="noopener">
										{item.org}
									</a>
								) : (
									<span class="org">{item.org}</span>
								)}
								{item.role && <span class="role">{item.role}</span>}
							</div>
							<p class="body">{item.body}</p>
							{item.link && (
								<a class="item-link" href={item.link} target="_blank" rel="noopener">
									View on GitHub
								</a>
							)}
						</div>
					</li>
				))
			}
		</ul>
	</section>
</Hero>

<style>
	/* On wide screens the bio fills the left column while Publications and
	   Contributions stack in the right column (grid defined in global.css);
	   each section renders as its own elevated card. */
	@media (min-width: 73.01rem) {
		#home {
			grid-column: 1;
			grid-row: 1 / span 2;
		}
		#publications {
			grid-column: 2;
			grid-row: 1;
		}
		#contributions {
			grid-column: 2;
			grid-row: 2;
		}
	}

	/* === Section headings === */
	.section-title {
		font-size: 1.35rem;
		letter-spacing: -0.01em;
		margin: 1.5rem 0 0.85rem;
	}
	.section-title:first-of-type {
		margin-top: 0.25rem;
	}

	/* === Home hero === */
	/* Contain the floated avatar within the hero. */
	.section-home::after {
		content: '';
		display: block;
		clear: both;
	}
	.hero-fact {
		margin: 0 0 0.85rem;
		font-size: 0.95rem;
		letter-spacing: 0.01em;
		color: rgba(255, 255, 255, 0.7);
	}
	.hero-tagline a {
		color: var(--link);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		text-decoration-color: color-mix(in srgb, var(--link) 45%, transparent);
		transition:
			color 0.18s ease,
			text-decoration-color 0.18s ease;
	}
	.hero-tagline a:hover,
	.hero-tagline a:focus-visible {
		color: var(--link-hover);
		text-decoration-color: var(--link-hover);
	}
	/* Circular avatar with a bright ring, floated to the top-right of the
	   intro text. */
	.hero-avatar {
		float: right;
		width: 150px;
		height: auto;
		margin: 0 0 0.75rem 1.25rem;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: 50%;
		box-shadow:
			0 0 0 2px rgba(255, 255, 255, 0.4),
			0 10px 30px rgba(0, 0, 0, 0.35);
		transition: transform 0.25s ease;
	}
	.hero-avatar:hover {
		transform: scale(1.04);
	}
	:root[data-theme='light'] .hero-avatar {
		box-shadow:
			0 0 0 2px rgba(0, 0, 0, 0.12),
			0 10px 30px rgba(0, 0, 0, 0.2);
	}

	/* === Papers === */
	.papers {
		list-style: none;
		padding: 0;
		margin: 1.25rem 0 0 0;
	}
	/* Rows bleed to the card edges so their hairlines and hover washes span
	   the full panel width; --card-pad-x comes from .card in global.css. */
	.paper {
		display: grid;
		grid-template-columns: 3rem 1fr;
		gap: 1rem;
		margin-inline: calc(-1 * var(--card-pad-x));
		padding: 0.8rem var(--card-pad-x);
		border-top: 1px solid var(--hairline);
		transition: background-color 0.2s ease;
	}
	.paper:hover {
		background-color: var(--row-hover);
	}
	.year {
		font-size: 0.85rem;
		font-variant-numeric: tabular-nums;
		opacity: 0.6;
		padding-top: 0.2rem;
		white-space: nowrap;
	}
	.content {
		min-width: 0;
	}
	.title {
		display: block;
		font-weight: 700;
		font-size: 1rem;
		line-height: 1.4;
		text-wrap: balance;
		color: var(--link);
		text-decoration: none;
	}
	.title:hover,
	.title:focus-visible {
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1.5px;
	}
	.authors {
		display: block;
		margin-top: 0.35rem;
		font-size: 0.92rem;
		line-height: 1.5;
	}
	.venue {
		display: block;
		margin-top: 0.2rem;
		font-size: 0.88rem;
		opacity: 0.7;
	}
	.cofirst {
		margin-left: 0.5rem;
		font-size: 0.8rem;
		opacity: 0.7;
	}

	/* === Contributions === */
	.news {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0 0;
	}
	.item {
		display: grid;
		grid-template-columns: 3rem 1fr;
		gap: 1rem;
		margin-inline: calc(-1 * var(--card-pad-x));
		padding: 0.8rem var(--card-pad-x);
		border-top: 1px solid var(--hairline);
		transition: background-color 0.2s ease;
	}
	.item:hover {
		background-color: var(--row-hover);
	}
	.date {
		font-size: 0.85rem;
		font-variant-numeric: tabular-nums;
		padding-top: 0.1rem;
		opacity: 0.65;
		white-space: nowrap;
	}
	.org-row {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
	}
	.org {
		font-weight: 700;
		font-size: 1rem;
		color: var(--link);
		text-decoration: none;
	}
	.role {
		font-size: 0.82rem;
		opacity: 0.7;
		white-space: nowrap;
	}
	.body {
		margin: 0.3rem 0 0 0;
		font-size: 0.92rem;
		line-height: 1.55;
	}
	.item-link {
		display: inline-flex;
		align-items: center;
		margin-top: 0.5rem;
		font-size: 0.8rem;
		color: var(--link);
		text-decoration: none;
		font-weight: 600;
		white-space: nowrap;
	}
	.item-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 32rem) {
		.hero-avatar {
			width: 120px;
		}
		.paper,
		.item {
			grid-template-columns: 1fr;
			gap: 0.3rem;
		}
		.year,
		.date {
			padding-top: 0;
		}
	}
</style>
