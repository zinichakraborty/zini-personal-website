---
import Hero from '../layouts/Hero.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<Hero title={SITE_TITLE} description={SITE_DESCRIPTION} centered>
	<h2 class="hero-name">Chandreyi <span class="hero-nick">(Zini)</span> Chakraborty</h2>
	<p class="hero-tagline">passionate about interpretable and efficient ai</p>
	<span slot="below" class="hero-penguin">
		<img class="penguin-still" src="/penguin-favicon.svg" alt="Penguin" width="256" height="256" />
		<img class="penguin-wave" src="/penguin-wave.svg" alt="" aria-hidden="true" width="256" height="256" />
	</span>
</Hero>

<style>
	.hero-penguin {
		position: relative;
		display: block;
		width: 256px;
		height: 256px;
		margin: 1.5rem 0 0;
		animation: penguin-bob 3s ease-in-out infinite;
	}
	@keyframes penguin-bob {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-8px);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-penguin {
			animation: none;
		}
	}
	.hero-nick {
		display: inline-block;
		transition:
			transform 0.2s ease,
			color 0.2s ease;
	}
	.hero-nick:hover {
		transform: scale(1.25);
		color: hsl(220, 100%, 70%);
	}
	@media (prefers-reduced-motion: reduce) {
		.hero-nick {
			transition: color 0.2s ease;
		}
	}
	.hero-penguin img {
		display: block;
		width: 256px;
		height: 256px;
	}
	.hero-penguin .penguin-wave {
		position: absolute;
		inset: 0;
		display: none;
	}
	.hero-penguin:hover .penguin-still {
		display: none;
	}
	.hero-penguin:hover .penguin-wave {
		display: block;
	}
</style>
