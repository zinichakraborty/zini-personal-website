---
import BaseHead from '../components/BaseHead.astro';
import ShaderBackground from '../components/ui/ShaderBackground.tsx';
import { SOCIALS } from '../consts';

interface Props {
	title: string;
	description: string;
	/** Vertically center the card and center its text (used by the homepage). */
	centered?: boolean;
	/** Use a much wider card (used by content-heavy pages). */
	wide?: boolean;
	/** Shrink the card to fit its widest line of content. */
	fit?: boolean;
}

const { title, description, centered = false, wide = false, fit = false } = Astro.props;

const nav = [
	{ label: 'Home', href: '/' },
	{ label: 'Background', href: '/background' },
	{ label: 'Papers', href: '/papers' },
	{ label: 'News', href: '/news' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<ShaderBackground client:load />

		<nav class="shader-nav">
			{
				nav.map((item) => (
					<a
						href={item.href}
						class={isActive(item.href) ? 'active' : undefined}
						aria-current={isActive(item.href) ? 'page' : undefined}
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<main class:list={['card-wrap', { center: centered }]}>
			<div class:list={['card', { 'card-centered': centered, 'card-wide': wide, 'card-fit': fit }]}>
				<slot />
			</div>
			<slot name="below" />
		</main>

		<footer class="shader-footer">
			<a href={SOCIALS.github} target="_blank" rel="noopener noreferrer">
				<span class="sr-only">GitHub</span>
